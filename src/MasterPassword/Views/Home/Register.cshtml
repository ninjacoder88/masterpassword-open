@using MasterPassword
@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Scripts {
    <script type="text/javascript" src="~/js/app/HomeRegisterViewModel.js?@AppVersion.QueryString"></script>
}

<h1>Register</h1>

<div id="container">
    <div class="row text-white">
        <div class="col-md-4 offset-md-4">
            <form>
                <div class="form-group">
                    <label>Username</label>
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" data-bind="value: username" placeholder="" aria-label="Recipient's username" aria-describedby="button-addon2">
                        <div class="input-group-append">
                            <button class="btn btn-outline-secondary" type="button" id="button-addon2">Button</button>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Email Address</label>
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" data-bind="value: emailAddress" placeholder="" aria-label="Recipient's username" aria-describedby="button-addon2">
                        <div class="input-group-append">
                            <button class="btn btn-outline-secondary" type="button" id="button-addon2">Button</button>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <div class="input-group mb-3">
                        <input type="password" class="form-control" data-bind="value: password" placeholder="" aria-label="Recipient's username" aria-describedby="button-addon2">
                        <div class="input-group-append">
                            <button class="btn btn-outline-secondary" type="button" id="button-addon2">Button</button>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Confirm Password</label>
                    <div class="input-group mb-3">
                        <input type="password" class="form-control" data-bind="value: confirmPassword" placeholder="" aria-label="confirm password" aria-describedby="button-addon2">
                        <div class="input-group-append">
                            <button class="btn btn-outline-secondary" type="button" id="confirmPassword">Button</button>
                        </div>
                    </div>
                </div>
                <button type="button" class="btn btn-primary" data-bind="click: createAccount, enable: createAccountEnabled">Register</button>
            </form>
        </div>
    </div>
</div><!--/container-->