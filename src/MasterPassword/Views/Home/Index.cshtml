@using MasterPassword
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Scripts {
    <script type="text/javascript" src="~/js/app/HomeIndexViewModel.js?@AppVersion.QueryString"></script>
}

<div id="container">
    <div class="text-center">
        <img src="https://masterpassword.xyz/logo2.png" class="img-fluid" />
    </div>
    <div class="row g-0">
        <div class="col-md-4 offset-md-4">
            <div class="mb-3">
                <label class="text-white">username</label>
                <input type="text" class="form-control" data-bind="value: username"/>
            </div>
            <div class="mb-3">
                <label class="text-white">password</label>
                <input type="password" class="form-control" data-bind="value: password"/>
            </div>
            <button type="button" class="btn btn-primary" data-bind="click: login, disable: loggingIn">Login</button>
            <a class="btn btn-secondary float-end" href="/home/register">Create Account</a>
            <div class="mt-3" data-bind="visible: hasError">
                <div class="alert alert-danger" role="alert"><span data-bind="text: errorMessage"></span></div>
            </div>
        </div>
    </div>
</div>

<footer class="footer mt-auto py-1 text-white">
    <div class="container">
        <p class="text-center">&copy; Ninjasoft LLC. 2025. Version @AppVersion.Version</p>
    </div>
</footer>